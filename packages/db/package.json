{
  "name": "@repo/db",
  "private": true,
  "scripts": {
    "prisma": "prisma --schema=./prisma/schema.prisma",
    "generate": "prisma generate --schema=./prisma/schema.prisma",
    "migrate:dev": "prisma migrate dev --schema=./prisma/schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "seed": "prisma db seed --schema=./prisma/schema.prisma",
    "studio": "prisma studio --schema=./prisma/schema.prisma"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.16.0"
  },
  "devDependencies": {
    "prisma": "^6.16.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
