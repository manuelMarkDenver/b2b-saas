generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppMeta {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum MembershipStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum TenantRole {
  OWNER
  ADMIN
  STAFF
  VIEWER
}

model User {
  id                   String             @id @default(uuid()) @db.Uuid
  email                String             @unique
  passwordHash         String
  status               UserStatus         @default(ACTIVE)
  isPlatformAdmin      Boolean            @default(false)
  avatarUrl            String?
  resetToken           String?            @unique
  resetTokenExpiresAt  DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  memberships          TenantMembership[]
  tenantsCreated       Tenant[]           @relation("TenantCreatedBy")
  notifications        Notification[]
  inventoryMovements   InventoryMovement[]
  transfersRequested   StockTransferRequest[] @relation("TransferRequester")
  transfersApproved    StockTransferRequest[] @relation("TransferApprover")
  purchaseOrdersCreated PurchaseOrder[] @relation("PurchaseOrderCreatedBy")
  purchaseOrdersReceived PurchaseOrder[] @relation("PurchaseOrderReceivedBy")
}

enum BranchStatus {
  ACTIVE
  INACTIVE
}

/// Describes the operational role of a branch.
/// Generic — any multi-location business can use these labels.
/// Has no effect on core logic; used for display, reporting, and transfer context.
enum BranchType {
  STANDARD      // default — general purpose branch
  PRODUCTION    // source of goods (factory, central kitchen, manufacturing)
  DISTRIBUTION  // hub that receives from production and dispatches to retail
  RETAIL        // end-point selling location
  WAREHOUSE     // pure storage, no direct sales
}

enum BusinessType {
  general_retail
  hardware
  food_beverage
  packaging_supply
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

model Tenant {
  id                 String              @id @default(uuid()) @db.Uuid
  name               String
  slug               String              @unique
  status             TenantStatus        @default(ACTIVE)
  businessType       BusinessType        @default(general_retail)
  features           Json                @default("{\"inventory\":true,\"orders\":true,\"payments\":true,\"marketplace\":false,\"stockTransfers\":false,\"paymentTerms\":false,\"multipleBranches\":false}")
  maxBranches        Int                 @default(1)
  isSystem           Boolean             @default(false)
  logoUrl            String?
  createdByUserId    String              @db.Uuid
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  createdByUser      User                @relation("TenantCreatedBy", fields: [createdByUserId], references: [id])
  memberships        TenantMembership[]
  branches           Branch[]
  products           Product[]
  skus               Sku[]
  inventoryMovements InventoryMovement[]
  orders             Order[]
  payments           Payment[]
  contacts           Contact[]
  suppliers          Supplier[]
  stockTransfers     StockTransferRequest[]
  purchaseOrders     PurchaseOrder[]
}

model Branch {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  name      String
  address   String?
  isDefault Boolean      @default(false)
  status    BranchStatus @default(ACTIVE)
  type      BranchType   @default(STANDARD)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenant          Tenant                 @relation(fields: [tenantId], references: [id])
  orders          Order[]
  movements       InventoryMovement[]
  transfersFrom   StockTransferRequest[] @relation("TransferFrom")
  transfersTo     StockTransferRequest[] @relation("TransferTo")
  purchaseOrders  PurchaseOrder[]

  @@index([tenantId])
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products  Product[]
}

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  categoryId  String   @db.Uuid
  name        String
  description String?
  isActive    Boolean  @default(true)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  category    Category @relation(fields: [categoryId], references: [id])
  skus        Sku[]

  @@index([tenantId])
  @@index([categoryId])
}

model Sku {
  id                 String              @id @default(uuid()) @db.Uuid
  tenantId           String              @db.Uuid
  productId          String              @db.Uuid
  code               String
  name               String
  priceCents         Int?
  costCents          Int?
  barcode            String?
  stockOnHand        Int                 @default(0)
  lowStockThreshold  Int                 @default(0)
  imageUrl           String?
  isActive           Boolean             @default(true)
  isArchived         Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  product            Product             @relation(fields: [productId], references: [id])
  inventoryMovements InventoryMovement[]
  orderItems         OrderItem[]
  transferItems      StockTransferItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([productId])
}

model TenantMembership {
  id                String           @id @default(uuid()) @db.Uuid
  tenantId          String           @db.Uuid
  userId            String           @db.Uuid
  status            MembershipStatus @default(ACTIVE)
  role              TenantRole       @default(STAFF)
  jobTitle          String?
  username          String?          // Login identifier for direct-add staff (no email). Scoped to tenant.
  branchIds         Json             @default("[]") // Array of Branch IDs. Empty = access to all branches.
  isOwner           Boolean          @default(false)
  inviteToken       String?          @unique
  inviteExpiresAt   DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  tenant            Tenant           @relation(fields: [tenantId], references: [id])
  user              User             @relation(fields: [userId], references: [id])

  @@unique([tenantId, userId])
  @@unique([tenantId, username])
  @@index([userId])
  @@index([tenantId])
  @@index([status])
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
}

enum ReferenceType {
  ORDER
  MANUAL
  TRANSFER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

// ─── Contact / AR ─────────────────────────────────────────────────────────────

enum ContactType {
  CUSTOMER
  DISTRIBUTOR
}

model Contact {
  id               String      @id @default(uuid()) @db.Uuid
  tenantId         String      @db.Uuid
  name             String
  type             ContactType @default(CUSTOMER)
  phone            String?
  address          String?
  /// 0 = COD / no credit extended. Set a positive value to enable AR tracking for this contact.
  creditLimitCents Int         @default(0)
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  tenant           Tenant      @relation(fields: [tenantId], references: [id])
  orders           Order[]

  @@index([tenantId])
  @@index([type])
}

// ─── Suppliers ────────────────────────────────────────────────────────────────

model Supplier {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ─── Purchase Orders ──────────────────────────────────────────────────────────

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  RECEIVED
  CLOSED
}

model PurchaseOrder {
  id            String               @id @default(uuid()) @db.Uuid
  tenantId      String               @db.Uuid
  branchId      String               @db.Uuid
  supplierId    String               @db.Uuid
  status        PurchaseOrderStatus  @default(DRAFT)
  poNumber      Int
  poDate        DateTime
  expectedOn    DateTime?
  note          String?
  createdById   String               @db.Uuid
  receivedById  String?              @db.Uuid
  orderedAt     DateTime?
  receivedAt    DateTime?
  closedAt      DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  branch        Branch               @relation(fields: [branchId], references: [id])
  supplier      Supplier             @relation(fields: [supplierId], references: [id])
  createdBy     User                 @relation("PurchaseOrderCreatedBy", fields: [createdById], references: [id])
  receivedBy    User?                @relation("PurchaseOrderReceivedBy", fields: [receivedById], references: [id])
  items         PurchaseOrderItem[]

  @@unique([tenantId, poNumber])
  @@index([tenantId])
  @@index([branchId])
  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid()) @db.Uuid
  purchaseOrderId String        @db.Uuid
  skuId           String        @db.Uuid
  orderedQty      Int
  receivedQty     Int           @default(0)
  purchaseCostCents Int         @default(0)

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  sku             Sku           @relation(fields: [skuId], references: [id])

  @@unique([purchaseOrderId, skuId])
  @@index([purchaseOrderId])
  @@index([skuId])
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id             String      @id @default(uuid()) @db.Uuid
  tenantId       String      @db.Uuid
  status         OrderStatus @default(PENDING)
  totalCents     Int         @default(0)
  branchId       String?     @db.Uuid
  /// Linked contact for AR tracking. Null = walk-in / untracked customer.
  contactId      String?     @db.Uuid
  customerRef    String?     // Free-text fallback when contactId is null: "Jollibee Branch 3", "PO #1234"
  note           String?     // Internal note for staff
  /// Credit due date for AR orders. Null = COD / no terms.
  paymentDueDate DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  branch     Branch?     @relation(fields: [branchId], references: [id])
  contact    Contact?    @relation(fields: [contactId], references: [id])
  items      OrderItem[]
  payments   Payment[]

  @@index([tenantId])
  @@index([branchId])
  @@index([contactId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id          String @id @default(uuid()) @db.Uuid
  orderId     String @db.Uuid
  skuId       String @db.Uuid
  quantity    Int
  priceAtTime Int
  /// Cost of the SKU at time of order — used for accurate COGS reporting.
  costAtTime  Int    @default(0)

  order       Order  @relation(fields: [orderId], references: [id], onDelete: Restrict)
  sku         Sku    @relation(fields: [skuId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([skuId])
}

// ─── Payments ─────────────────────────────────────────────────────────────────

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PaymentMethod {
  CASH
  GCASH
  MAYA
  BANK_TRANSFER
  CARD
  CHEQUE
}

model Payment {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @db.Uuid
  orderId     String        @db.Uuid
  amountCents Int
  status      PaymentStatus @default(PENDING)
  method      PaymentMethod @default(CASH)
  proofUrl    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([orderId])
  @@index([status])
  @@index([method])
}

// ─── Inventory ────────────────────────────────────────────────────────────────

model InventoryMovement {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @db.Uuid
  skuId          String         @db.Uuid
  type           MovementType
  quantity       Int
  referenceType  ReferenceType
  referenceId    String?
  note           String?
  reason         String?
  approvalStatus ApprovalStatus @default(APPROVED)
  actorId        String?        @db.Uuid
  branchId       String?        @db.Uuid
  /// Links the TRANSFER_OUT movement to its corresponding TRANSFER_IN movement.
  transferPairId String?        @db.Uuid
  /// Reserved for future batch/lot tracking. Nullable until the Batch model is introduced.
  batchId        String?        @db.Uuid
  createdAt      DateTime       @default(now())

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  sku            Sku            @relation(fields: [skuId], references: [id], onDelete: Restrict)
  branch         Branch?        @relation(fields: [branchId], references: [id])
  actor          User?          @relation(fields: [actorId], references: [id])

  @@index([tenantId])
  @@index([skuId])
  @@index([branchId])
  @@index([approvalStatus])
  @@index([actorId])
  @@index([transferPairId])
}

// ─── Stock Transfers ──────────────────────────────────────────────────────────

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
  FULFILLED
}

model StockTransferRequest {
  id            String         @id @default(uuid()) @db.Uuid
  tenantId      String         @db.Uuid
  /// Null = HQ / no specific source branch
  fromBranchId  String?        @db.Uuid
  toBranchId    String         @db.Uuid
  status        TransferStatus @default(PENDING)
  requestedById String         @db.Uuid
  approvedById  String?        @db.Uuid
  note          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  fromBranch    Branch?        @relation("TransferFrom", fields: [fromBranchId], references: [id])
  toBranch      Branch         @relation("TransferTo", fields: [toBranchId], references: [id])
  requestedBy   User           @relation("TransferRequester", fields: [requestedById], references: [id])
  approvedBy    User?          @relation("TransferApprover", fields: [approvedById], references: [id])
  items         StockTransferItem[]

  @@index([tenantId])
  @@index([status])
  @@index([fromBranchId])
  @@index([toBranchId])
}

model StockTransferItem {
  id         String               @id @default(uuid()) @db.Uuid
  transferId String               @db.Uuid
  skuId      String               @db.Uuid
  quantity   Int

  transfer   StockTransferRequest @relation(fields: [transferId], references: [id])
  sku        Sku                  @relation(fields: [skuId], references: [id])

  @@index([transferId])
  @@index([skuId])
}

// ─── Notifications ────────────────────────────────────────────────────────────

enum NotificationType {
  ORDER_CREATED
  ORDER_CONFIRMED
  ORDER_CANCELLED
  PAYMENT_SUBMITTED
  PAYMENT_VERIFIED
  PAYMENT_REJECTED
  LOW_STOCK
  STAFF_ADDED
  TENANT_SUSPENDED
  PLATFORM_ALERT
}

model Notification {
  id         String           @id @default(uuid()) @db.Uuid
  tenantId   String?          @db.Uuid
  userId     String           @db.Uuid
  type       NotificationType
  title      String
  body       String
  entityType String?
  entityId   String?          @db.Uuid
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())

  user       User             @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([tenantId])
}
