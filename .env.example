# Local development defaults (copy to .env)

# Docker Postgres
POSTGRES_DB=b2b_saas
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5442

# API
API_PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5442/b2b_saas?schema=public
LOG_LEVEL=debug
LOG_PRETTY=1

# WEB
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
