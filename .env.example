# Environment variable reference — Zentral
# Copy to .env and fill in values for your environment.
# Last updated: 2026-04-03

# ── Database ─────────────────────────────────────────────────────────────────
# Local: Docker Postgres (see infra/docker-compose.yml)
# Staging/Prod: Neon connection string
DATABASE_URL=postgresql://user:password@host:port/dbname?schema=public

# ── API ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug
LOG_PRETTY=true

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=dev_change_me_please_32chars_min
JWT_EXPIRES_IN_SECONDS=604800

# ── Rate limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=10

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated; production: your Vercel URL(s)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── URLs ─────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3001
APP_FRONTEND_URL=http://localhost:3000

# ── Email ────────────────────────────────────────────────────────────────────
# Local: Mailpit (run via docker-compose up mailpit)
# Production: Resend (smtp.resend.com, port 587, user=resend)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@localhost

# ── File Storage ─────────────────────────────────────────────────────────────
# STORAGE_TYPE=local  → files saved to apps/api/uploads/, served at /uploads/*
# STORAGE_TYPE=s3     → works for both AWS S3 and Cloudflare R2
STORAGE_TYPE=local

# Cloudflare R2 (production — recommended, free tier, zero egress):
AWS_REGION=auto
AWS_S3_ENDPOINT=                           # R2: https://<account-id>.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=                             # e.g. zentral-uploads
AWS_S3_PUBLIC_URL=                         # R2: https://pub-<account-id>.r2.dev

# AWS S3 (alternative):
# AWS_REGION=ap-southeast-1
# AWS_S3_ENDPOINT=                         # leave blank for standard AWS S3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_S3_PUBLIC_URL=https://your-bucket.s3.ap-southeast-1.amazonaws.com

# ── Seed (admin bootstrap) ───────────────────────────────────────────────────
ADMIN_EMAIL=admin@local.test
ADMIN_PASSWORD=ChangeMe123!
ADMIN_TENANT_NAME=Admin Tenant
ADMIN_TENANT_SLUG=admin
SEED_DEFAULT_PASSWORD=Password123!
