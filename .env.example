# Local development defaults (copy to .env)

# Docker Postgres
POSTGRES_DB=b2b_saas
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5442

# API
API_PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5442/b2b_saas?schema=public
LOG_LEVEL=debug
LOG_PRETTY=1
JWT_SECRET=dev_change_me_please_32chars_min
JWT_EXPIRES_IN_SECONDS=604800

# WEB
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Seed (admin bootstrap)
ADMIN_EMAIL=admin@local.test
ADMIN_PASSWORD=ChangeMe123!
ADMIN_TENANT_NAME=Admin Tenant
ADMIN_TENANT_SLUG=admin

# Seed (test users)
SEED_DEFAULT_PASSWORD=Password123!

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=10

# CORS (comma-separated; production: your Vercel URL)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Email (local: Mailpit — docker-compose up mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@localhost
APP_BASE_URL=http://localhost:3000
