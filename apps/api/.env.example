PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5442/b2b_saas?schema=public
LOG_LEVEL=debug
LOG_PRETTY=1
JWT_SECRET=dev_change_me_please_32chars_min
JWT_EXPIRES_IN_SECONDS=604800

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=10

# CORS (comma-separated; production: your Vercel URL)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Email (local: Mailpit — run via docker-compose)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@localhost

APP_BASE_URL=http://localhost:3001
APP_FRONTEND_URL=http://localhost:3000

# ── File uploads ──────────────────────────────────────────────────────────────
# STORAGE_TYPE=local  → files saved to apps/api/uploads/, served at /uploads/*
# STORAGE_TYPE=s3     → works for both AWS S3 and Cloudflare R2
STORAGE_TYPE=local

# Cloudflare R2 (production — recommended, free tier, zero egress):
# AWS_REGION=auto
# AWS_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=ascendex-uploads
# AWS_S3_PUBLIC_URL=https://pub-xxxx.r2.dev

# AWS S3 (alternative):
# AWS_REGION=ap-southeast-1
# AWS_S3_ENDPOINT=           (leave blank for standard AWS S3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_S3_PUBLIC_URL=https://your-bucket.s3.ap-southeast-1.amazonaws.com
