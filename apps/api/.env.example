PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5442/b2b_saas?schema=public
LOG_LEVEL=debug
LOG_PRETTY=1
JWT_SECRET=dev_change_me_please_32chars_min
JWT_EXPIRES_IN_SECONDS=604800

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=10

# CORS (comma-separated; production: your Vercel URL)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Email (local: Mailpit — run via docker-compose)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@localhost
APP_BASE_URL=http://localhost:3000
